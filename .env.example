# Copy this file to .env and fill in real values. .env is gitignored.

# --- LLM provider selection ---
# One of: gemini | anthropic. See docs/adr/0013. "gemini" is the default and
# the only provider required to run the system end to end.
LLM_PROVIDER=gemini

# --- Gemini (required when LLM_PROVIDER=gemini, the default) ---
# Used for RAG generation and, for now, the eval LLM-judge (see ADR-0013 for
# the self-preference-bias caveat on using one model for both). Get a free
# key from Google AI Studio -- no billing account needed.
GEMINI_API_KEY=
# Optional override; defaults to the current stable Flash-Lite model.
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Anthropic (optional, NOT used by default) ---
# Only read if LLM_PROVIDER=anthropic. Kept as a second working
# LLMProvider implementation to demonstrate the provider abstraction from
# ADR-0003 -- not on the default code path, and not required to run this
# project. See docs/adr/0013 for why Anthropic isn't the default.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Postgres (pgvector) ---
# Credentials used by both the postgres container and the api's DATABASE_URL.
POSTGRES_USER=meridian
POSTGRES_PASSWORD=meridian
POSTGRES_DB=meridian
POSTGRES_PORT=5432
# Full SQLAlchemy async connection string the api container connects with.
DATABASE_URL=postgresql+asyncpg://meridian:meridian@postgres:5432/meridian

# --- Redis ---
REDIS_PORT=6379
# Connection string the api container connects with.
REDIS_URL=redis://redis:6379/0

# --- Embeddings ---
# One of: local | voyage. "openai" is a documented future option, not yet
# implemented -- see docs/adr/0004. "local" needs no key.
EMBEDDING_PROVIDER=local
# Only required if EMBEDDING_PROVIDER=voyage.
VOYAGE_API_KEY=
# Optional override; defaults to a small, cheap Voyage model.
VOYAGE_MODEL=voyage-3-lite
# Reserved for a future EMBEDDING_PROVIDER=openai implementation.
OPENAI_API_KEY=

# --- Retrieval (see docs/adr/0007) ---
# All optional; sane defaults are set in app/config.py. Fetched from both
# vector and full-text search before fusion.
RETRIEVAL_CANDIDATE_POOL_SIZE=25
# Chunks passed to the LLM for answer generation, after fusion.
RETRIEVAL_TOP_K=8
# Fusion weights for normalized cosine-similarity vs. full-text rank.
RETRIEVAL_VECTOR_WEIGHT=0.6
RETRIEVAL_TEXT_WEIGHT=0.4

# --- Guardrails (see docs/adr/0008) ---
# Minimum raw cosine similarity for a retrieved chunk, when nothing also
# matched via full-text search, before the ask flow will attempt an answer.
RETRIEVAL_CONFIDENCE_THRESHOLD=0.3
# Minimum self-reported confidence for an extracted Decision/ActionItem to
# be persisted; lower-confidence items are dropped rather than recorded.
EXTRACTION_CONFIDENCE_THRESHOLD=0.5

# --- API service ---
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list of origins allowed to call the API from a browser.
# Must match the *browser-facing* origin the web app is actually served
# from -- i.e. this needs http://localhost:${WEB_PORT} below, not a
# hardcoded 3000, if you change WEB_PORT. A mismatch here fails silently
# as a CORS rejection in the browser console, not a clear error.
CORS_ORIGINS=http://localhost:3000

# --- Web service ---
WEB_PORT=3000
# Base URL the browser uses to reach the api service.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- MCP server (apps/mcp_server, see docs/adr/0011) ---
# Base URL the MCP server calls to reach the running api service. Not read
# by docker-compose (the MCP server runs as a local stdio process spawned
# by an MCP host, e.g. Claude Desktop/Code -- see README setup section),
# only by the MCP server itself.
MERIDIAN_API_BASE_URL=http://localhost:8000
